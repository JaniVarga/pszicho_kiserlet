import cv2
import numpy as np
import mediapipe as mp
from mediapipe.tasks import python
from mediapipe.tasks.python import vision
import csv
import datetime
import time

class ObjectTracking:
    def __init__(self, camera_id=1):
        self.cam_id = camera_id
        # 2. ÚJ MEDIAPIPE AI INICIALIZÁLÁSA (Blendshapes)
        base_options = python.BaseOptions(model_asset_path='face_landmarker.task')
        options = vision.FaceLandmarkerOptions(
            base_options=base_options,
            output_face_blendshapes=True,  # EZ A LÉNYEG: Bekapcsolja az 52 arcizom elemzést!
            output_facial_transformation_matrixes=False,
            num_faces=1
        )
        self.detector = vision.FaceLandmarker.create_from_options(options)

        print("MediaPipe Blendshapes sikeresen betöltve!")

    def run(self):
        frame_id = 1
        header_written = False
        timestep = datetime.datetime.now().strftime("%d%m%Y_%H%M%S")

        with open(f"data_{timestep}.csv", "a", newline="") as f:
            writer = csv.writer(f)

            cap = cv2.VideoCapture(self.cam_id)
            # cap.set(cv2.CAP_PROP_FRAME_WIDTH, 1280)
            # cap.set(cv2.CAP_PROP_FRAME_HEIGHT, 720)


            if not cap.isOpened():
                print(f"Hiba a kamerával. (ID: {self.cam_id})")

                return

            try:
                cap.set(cv2.CAP_PROP_FPS, 60)

                # Lekérdezzük, hogy tényleg sikerült-e átállítani
                aktualis_fps = cap.get(cv2.CAP_PROP_FPS)
                print(f"Sikerült beállítani? Az aktuális FPS: {aktualis_fps}")
                start_time = time.perf_counter()
                while True:
                    ret, frame = cap.read()
                    if not ret:
                        break

                    # 1. RGB konverzió a MediaPipe-nak
                    rgb_frame = cv2.cvtColor(frame, cv2.COLOR_BGR2RGB)
                    mp_image = mp.Image(image_format=mp.ImageFormat.SRGB, data=rgb_frame)
                    timestamp_ms = (time.perf_counter() - start_time) * 1000
                    # 2. AI detektálás
                    detection_result = self.detector.detect(mp_image)

                    # 3. Adatok kinyerése
                    if detection_result.face_blendshapes:
                        blendshapes = detection_result.face_blendshapes[0]

                        # Fejléc
                        if not header_written:
                            category_names = [blendshape.category_name for blendshape in blendshapes]
                            category_names[:0] = ["frame_id", "timestamp_ms"]
                            writer.writerow(category_names)
                            header_written = True

                        # Értékek
                        scores = [blendshape.score for blendshape in blendshapes]
                        scores[:0] = [frame_id,timestamp_ms]
                        writer.writerow(scores)

                        cv2.putText(frame, "Arc elemezve...", (30, 50), cv2.FONT_HERSHEY_DUPLEX, 0.7, (0, 255, 0), 2)

                    cv2.imshow("Main Camera", frame)
                    frame_id += 1

                    # 4. KILÉPÉS (Pontosan a while ciklus alatt)
                    if cv2.waitKey(1) & 0xFF == ord('q'):
                        break

            except Exception as e:
                print(f"Váratlan hiba történt a feldolgozás során: {e}")
            finally:
                cap.release()
                cv2.destroyAllWindows()
                print("Lezárva.")


if __name__ == "__main__":
    tracker = ObjectTracking(camera_id=0)
    tracker.run()
